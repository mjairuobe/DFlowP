# DFlowP Refine/Vite-Frontend: Build mit Node, Auslieferung per nginx (statische dist).
# Build-Kontext: Repository-Root (siehe docker-compose, Jenkinsfile-Frontend).
#
# @see dflowp/frontend/package.json (npm run build → tsc && refine build)

FROM node:22-bookworm AS build

WORKDIR /app

COPY dflowp/frontend/package.json dflowp/frontend/package-lock.json dflowp/frontend/.npmrc ./
RUN npm ci

COPY dflowp/frontend/ ./
ENV NODE_ENV=production
RUN npm run build

FROM nginx:1.27-alpine

COPY --from=build /app/dist /usr/share/nginx/html
COPY docker/dflowp-frontend/default.conf /etc/nginx/conf.d/default.conf
EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
