    // Abstrakte CI: modules.json → Packages + Services, Tree-Tags, partieller Build
    // Skripte: scripts/ci_*.py (Python 3.11+)

    pipeline {
        agent any

        options {
            timestamps()
            timeout(time: 60, unit: 'MINUTES')
        }

        environment {
            DOCKERHUB_CREDS_ID = 'dockerhub-creds'
        }

        stages {
            stage('Checkout') {
                steps {
                    checkout scm
                }
            }

            stage('Fetch git tags') {
                steps {
                    sh '''
                        set -e
                        cd "${WORKSPACE}"
                        if [ -d modular-ci-template ]; then cd modular-ci-template; fi
                        git remote get-url origin >/dev/null 2>&1 && git fetch origin --tags --force || git fetch --tags --force || true
                        git tag -l 'v*' | tail -5 || true
                    '''
                }
            }

            stage('Resolve version & tree') {
                steps {
                    sh '''
                        set -e
                        cd "${WORKSPACE}"
                        if [ -d modular-ci-template ]; then cd modular-ci-template; fi
                        # Python 3.11+ (wie DFlowP)
                        python3.11 scripts/ci_resolve_version.py
                        . ./.jenkins_runtime.env
                        echo "SOFTWARE_VERSION=${SOFTWARE_VERSION}"
                    '''
                }
            }

            stage('Build plan') {
                steps {
                    sh '''
                        set -e
                        cd "${WORKSPACE}"
                        if [ -d modular-ci-template ]; then cd modular-ci-template; fi
                        python3.11 scripts/ci_build_plan.py
                        cat .jenkins_skip_pipeline || true
                    '''
                }
            }

            stage('Cleanup containers') {
                when {
                    expression {
                        def p = fileExists('modular-ci-template/.jenkins_skip_pipeline') ? 'modular-ci-template/.jenkins_skip_pipeline' : '.jenkins_skip_pipeline'
                        return !fileExists(p) || readFile(p).trim() != 'true'
                    }
                }
                steps {
                    sh '''
                        docker container stop $(docker container ls -aq) 2>/dev/null || true
                        docker container rm $(docker container ls -aq) 2>/dev/null || true
                    '''
                }
            }

            stage('Generate Dockerfile') {
                when {
                    expression {
                        def p = fileExists('modular-ci-template/.jenkins_skip_pipeline') ? 'modular-ci-template/.jenkins_skip_pipeline' : '.jenkins_skip_pipeline'
                        return !fileExists(p) || readFile(p).trim() != 'true'
                    }
                }
                steps {
                    sh '''
                        set -e
                        cd "${WORKSPACE}"
                        if [ -d modular-ci-template ]; then cd modular-ci-template; fi
                        python3.11 scripts/ci_generate_dockerfile.py
                    '''
                }
            }

            stage('Docker build (selective)') {
                when {
                    expression {
                        def p = fileExists('modular-ci-template/.jenkins_skip_pipeline') ? 'modular-ci-template/.jenkins_skip_pipeline' : '.jenkins_skip_pipeline'
                        return !fileExists(p) || readFile(p).trim() != 'true'
                    }
                }
                steps {
                    sh '''
                        set -e
                        cd "${WORKSPACE}"
                        if [ -d modular-ci-template ]; then cd modular-ci-template; fi
                        python3.11 scripts/ci_docker_build.py
                    '''
                }
            }

            stage('Compose up') {
                when {
                    expression {
                        def p = fileExists('modular-ci-template/.jenkins_skip_pipeline') ? 'modular-ci-template/.jenkins_skip_pipeline' : '.jenkins_skip_pipeline'
                        return !fileExists(p) || readFile(p).trim() != 'true'
                    }
                }
                steps {
                    sh '''
                        set -e
                        cd "${WORKSPACE}"
                        if [ -d modular-ci-template ]; then cd modular-ci-template; fi
                        . ./.jenkins_runtime.env
                        set -a
                        . ./.jenkins_build_plan.env
                        eval "$(python3.11 scripts/ci_compose_env.py)"
                        set +a
                        docker compose up -d
                        docker compose ps
                    '''
                }
            }

            stage('Verify stack') {
                when {
                    expression {
                        def p = fileExists('modular-ci-template/.jenkins_skip_pipeline') ? 'modular-ci-template/.jenkins_skip_pipeline' : '.jenkins_skip_pipeline'
                        return !fileExists(p) || readFile(p).trim() != 'true'
                    }
                }
                steps {
                    sh '''
                        set -e
                        cd "${WORKSPACE}"
                        if [ -d modular-ci-template ]; then cd modular-ci-template; fi
                        docker compose ps
                    '''
                }
            }

            stage('Docker Hub push') {
                when {
                    expression {
                        def p = fileExists('modular-ci-template/.jenkins_skip_pipeline') ? 'modular-ci-template/.jenkins_skip_pipeline' : '.jenkins_skip_pipeline'
                        return !fileExists(p) || readFile(p).trim() != 'true'
                    }
                }
                steps {
                    withCredentials([
                        usernamePassword(credentialsId: "${DOCKERHUB_CREDS_ID}", usernameVariable: 'DOCKERHUB_USERNAME', passwordVariable: 'DOCKERHUB_PASSWORD')
                    ]) {
                        sh '''
                            set -e
                            cd "${WORKSPACE}"
                            if [ -d modular-ci-template ]; then cd modular-ci-template; fi
                            . ./.jenkins_runtime.env
                            . ./.jenkins_build_plan.env
                            echo "${DOCKERHUB_PASSWORD}" | docker login -u "${DOCKERHUB_USERNAME}" --password-stdin
                            python3.11 scripts/ci_docker_push.py
                            docker logout || true
                        '''
                    }
                }
            }
        }

        post {
            success {
                script {
                    def p = fileExists('modular-ci-template/.jenkins_skip_pipeline') ? 'modular-ci-template/.jenkins_skip_pipeline' : '.jenkins_skip_pipeline'
                    if (fileExists(p) && readFile(p).trim() == 'true') {
                        echo '=== SKIP: Stack entspricht bereits den erwarteten Tree-Tags. ==='
                    }
                }
            }
        }
    }
