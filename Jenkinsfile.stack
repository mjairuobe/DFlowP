// DFlowP stack pipeline (vereinfachte Full-Flow-Variante mit docker buildx).
// Fokus: klare Stages, parallele Buildx-Builds mit Cache, compose up + Integrationstests.
pipeline {
    agent any
    options {
        timestamps()
        timeout(time: 90, unit: 'MINUTES')
    }
    environment {
        MONGODB_TEST_DB = 'dflowp_test'
    }
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        stage('Preflight tools') {
            steps {
                sh '''set -euo pipefail
docker version
docker buildx version
docker-compose version
'''
            }
        }
        stage('Prepare version & image env') {
            steps {
                sh '''set -euo pipefail
git remote get-url origin >/dev/null 2>&1 && git fetch origin --tags --force || true
LATEST=$(git tag -l 'v[0-9]*.*.*' 2>/dev/null | sort -V | tail -1 || true)
if [ -n "${LATEST}" ]; then
  V=${LATEST#v}; MAJ=${V%%.*}; R1=${V#*.}; MIN=${R1%%.*}
  BN=$(git rev-list --count --all ${LATEST}..HEAD 2>/dev/null || echo 0)
  SOFTWARE_VERSION="v${MAJ}.${MIN}.${BN}"
else
  BN=$(git rev-list --all --count 2>/dev/null || echo 0)
  SOFTWARE_VERSION="v0.1.${BN}"
fi
GIT_SHORT=$(git rev-parse --short=12 HEAD)
STACK_TAG="stack-${GIT_SHORT}"
DOCKERHUB_REGISTRY="${DOCKERHUB_REGISTRY:-docker.io}"
DOCKERHUB_NAMESPACE="${DOCKERHUB_NAMESPACE:-crawlabase}"
IMAGE_REPO_BASE="${DOCKERHUB_REGISTRY}/${DOCKERHUB_NAMESPACE}"
DOCKERHUB_CACHE_REPO="${DOCKERHUB_CACHE_REPO:-${IMAGE_REPO_BASE}/dflowp-buildcache}"

cat > .jenkins_runtime.env <<EOF
SOFTWARE_VERSION=${SOFTWARE_VERSION}
STACK_TAG=${STACK_TAG}
DOCKERHUB_REGISTRY=${DOCKERHUB_REGISTRY}
DOCKERHUB_NAMESPACE=${DOCKERHUB_NAMESPACE}
IMAGE_REPO_BASE=${IMAGE_REPO_BASE}
DOCKERHUB_CACHE_REPO=${DOCKERHUB_CACHE_REPO}
EOF

cat > .jenkins_stack_images.env <<EOF
DOCKER_IMAGE_MONGO=${IMAGE_REPO_BASE}/dflowp-mongo:${STACK_TAG}
DOCKER_IMAGE_API=${IMAGE_REPO_BASE}/dflowp-api:${STACK_TAG}
DOCKER_IMAGE_FRONTEND=${IMAGE_REPO_BASE}/dflowp-frontend:${STACK_TAG}
DOCKER_IMAGE_RUNTIME=${IMAGE_REPO_BASE}/dflowp-runtime:${STACK_TAG}
DOCKER_IMAGE_EVENTSYSTEM=${IMAGE_REPO_BASE}/dflowp-eventsystem:${STACK_TAG}
DOCKER_IMAGE_EVENT_BROKER=${IMAGE_REPO_BASE}/dflowp-event-broker:${STACK_TAG}
DOCKER_IMAGE_PLUGIN_FETCHFEEDITEMS=${IMAGE_REPO_BASE}/dflowp-plugin-fetchfeeditems:${STACK_TAG}
DOCKER_IMAGE_PLUGIN_EMBEDDATA=${IMAGE_REPO_BASE}/dflowp-plugin-embeddata:${STACK_TAG}
DOCKER_IMAGE_PLUGIN_CLUSTERING_DBSCAN=${IMAGE_REPO_BASE}/dflowp-plugin-clustering-dbscan:${STACK_TAG}
DOCKER_IMAGE_PLUGIN_CLUSTERING_HDBSCAN=${IMAGE_REPO_BASE}/dflowp-plugin-clustering-hdbscan:${STACK_TAG}
EOF

echo "SOFTWARE_VERSION=${SOFTWARE_VERSION}"
echo "STACK_TAG=${STACK_TAG}"
echo "IMAGE_REPO_BASE=${IMAGE_REPO_BASE}"
echo "DOCKERHUB_CACHE_REPO=${DOCKERHUB_CACHE_REPO}"
'''
            }
        }
        stage('Docker Hub login') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'dockerhub-creds', usernameVariable: 'HUBU', passwordVariable: 'HUBP')]) {
                    sh '''set -euo pipefail
echo "${HUBP}" | docker login -u "${HUBU}" --password-stdin docker.io
'''
                }
            }
        }
        stage('Prepare Buildx builder') {
            steps {
                sh '''set -euo pipefail
RAW="dflowp-stack-${JOB_BASE_NAME:-job}"
BUILDER_NAME=$(printf '%s' "${RAW}" | tr '[:upper:]' '[:lower:]' | tr -cs 'a-z0-9_.-' '-')
echo "BUILDER_NAME=${BUILDER_NAME}" > .jenkins_buildx.env

if ! docker buildx inspect "${BUILDER_NAME}" >/dev/null 2>&1; then
  docker buildx create --name "${BUILDER_NAME}" --driver docker-container
fi
docker buildx use "${BUILDER_NAME}"
docker buildx inspect --bootstrap
'''
            }
        }
        stage('Build images (buildx parallel + registry cache/push)') {
            steps {
                sh '''set -euo pipefail
set -a
. ./.jenkins_runtime.env
. ./.jenkins_stack_images.env
. ./.jenkins_buildx.env
set +a

: "${BUILDER_NAME?}"
: "${SOFTWARE_VERSION?}"
: "${DOCKERHUB_CACHE_REPO?}"

GIT_REV=$(git rev-parse HEAD)
MAX_PARALLEL=2

build_target() {
  IFS='|' read -r svc dockerfile image <<< "$1"
  cache_ref="${DOCKERHUB_CACHE_REPO}:${svc}"
  echo "=== buildx ${svc} (${dockerfile} -> ${image}) ==="
  docker buildx build \
    --builder "${BUILDER_NAME}" \
    --file "${dockerfile}" \
    --tag "${image}" \
    --push \
    --cache-from "type=registry,ref=${cache_ref}" \
    --cache-to "type=registry,ref=${cache_ref},mode=max" \
    --label "org.opencontainers.image.version=${SOFTWARE_VERSION}" \
    --label "org.opencontainers.image.revision=${GIT_REV}" \
    .
}

targets=(
  "mongo|Dockerfile.mongo|${DOCKER_IMAGE_MONGO}"
  "api|Dockerfile.api|${DOCKER_IMAGE_API}"
  "frontend|Dockerfile-Frontend|${DOCKER_IMAGE_FRONTEND}"
  "worker|Dockerfile.worker|${DOCKER_IMAGE_RUNTIME}"
  "eventsystem|Dockerfile.eventsystem|${DOCKER_IMAGE_EVENTSYSTEM}"
  "event-broker|Dockerfile.event_broker|${DOCKER_IMAGE_EVENT_BROKER}"
  "plugin-fetchfeeditems|Dockerfile.plugin_fetchfeeditems|${DOCKER_IMAGE_PLUGIN_FETCHFEEDITEMS}"
  "plugin-embeddata|Dockerfile.plugin_embeddata|${DOCKER_IMAGE_PLUGIN_EMBEDDATA}"
  "plugin-clustering-dbscan|Dockerfile.plugin_clustering_dbscan|${DOCKER_IMAGE_PLUGIN_CLUSTERING_DBSCAN}"
  "plugin-clustering-hdbscan|Dockerfile.plugin_clustering_hdbscan|${DOCKER_IMAGE_PLUGIN_CLUSTERING_HDBSCAN}"
)

running=0
for target in "${targets[@]}"; do
  build_target "${target}" &
  running=$((running + 1))
  if [ "${running}" -ge "${MAX_PARALLEL}" ]; then
    if ! wait -n; then
      wait || true
      exit 1
    fi
    running=$((running - 1))
  fi
done
wait
'''
            }
        }
        stage('Compose up') {
            steps {
                withCredentials([
                    usernamePassword(credentialsId: 'mongodb-creds', usernameVariable: 'MONGODB_USERNAME', passwordVariable: 'MONGODB_PASSWORD'),
                    string(credentialsId: 'openai-api-key', variable: 'OPENAI_API_KEY'),
                    string(credentialsId: 'DFlowP_API_Key', variable: 'DFlowP_API_Key')
                ]) {
                    sh '''set -euo pipefail
set -a
. ./.jenkins_runtime.env
. ./.jenkins_stack_images.env
set +a

unwrap_one() {
  _n="$1"; _v="$2"
  case "${_v}" in
    "{")
      printf %s "${_v}"
      ;;
    "{"*)
      echo "${_v}" | jq -r --arg k "${_n}" 'if type == "object" then .[$k] // . else . end' 2>/dev/null | sed -n '1p'
      ;;
    *)
      printf %s "${_v}"
      ;;
  esac
}

export OPENAI_API_KEY=$(unwrap_one "OPENAI_API_KEY" "${OPENAI_API_KEY:-}")
export DFlowP_API_Key=$(unwrap_one "DFlowP_API_Key" "${DFlowP_API_Key:-}")
export SOFTWARE_VERSION

mkdir -p volumes/mongo
if ! chmod a+rwx volumes/mongo 2>/dev/null && ! chmod 777 volumes/mongo 2>/dev/null; then
  docker run --rm --user root -v "$(pwd)/volumes/mongo:/v:rw" alpine:3.20 sh -ceu 'chmod -R 777 /v' || true
fi

docker-compose -f docker-compose.yml down --remove-orphans 2>/dev/null || true
docker rm -f dflowp-frontend 2>/dev/null || true
docker-compose -f docker-compose.yml config -q
docker-compose -f docker-compose.yml pull
docker-compose -f docker-compose.yml up -d --no-build
docker-compose -f docker-compose.yml ps
'''
                }
            }
        }
        stage('Integration tests (API, Runtime, Plugins, Events)') {
            steps {
                withCredentials([
                    usernamePassword(credentialsId: 'mongodb-creds', usernameVariable: 'MONGODB_USERNAME', passwordVariable: 'MONGODB_PASSWORD'),
                    string(credentialsId: 'openai-api-key', variable: 'OPENAI_API_KEY'),
                    string(credentialsId: 'DFlowP_API_Key', variable: 'DFlowP_API_Key')
                ]) {
                    sh '''set -euo pipefail
set -a
. ./.jenkins_runtime.env
. ./.jenkins_stack_images.env
set +a

unwrap_one() {
  _n="$1"; _v="$2"
  case "${_v}" in
    "{")
      printf %s "${_v}"
      ;;
    "{"*)
      echo "${_v}" | jq -r --arg k "${_n}" 'if type == "object" then .[$k] // . else . end' 2>/dev/null | sed -n '1p'
      ;;
    *)
      printf %s "${_v}"
      ;;
  esac
}

export OPENAI_API_KEY=$(unwrap_one "OPENAI_API_KEY" "${OPENAI_API_KEY:-}")
export DFlowP_API_Key=$(unwrap_one "DFlowP_API_Key" "${DFlowP_API_Key:-}")
export SOFTWARE_VERSION

docker-compose -f docker-compose.yml run --rm -e "MONGODB_TEST_DB=${MONGODB_TEST_DB}" api \
  pytest tests/api_test.py -v --tb=short

docker-compose -f docker-compose.yml run --rm -e "MONGODB_TEST_DB=${MONGODB_TEST_DB}" worker \
  pytest tests/process_test.py tests/runtime_event_listener_test.py tests/logging_test.py tests/database_test.py -v --tb=short

docker-compose -f docker-compose.yml run --rm plugin-fetchfeeditems \
  pytest tests/plugin_services_test.py::test_plugin_directories_exist tests/plugin_services_test.py::test_fetch_plugin_info_and_health -v --tb=short

docker-compose -f docker-compose.yml run --rm plugin-embeddata \
  pytest tests/plugin_services_test.py::test_embed_plugin_info_and_health -v --tb=short

docker-compose -f docker-compose.yml run --rm -e "MONGODB_TEST_DB=${MONGODB_TEST_DB}" event-broker \
  pytest tests/event_broker_test.py -v --tb=short

docker-compose -f docker-compose.yml run --rm -e "MONGODB_TEST_DB=${MONGODB_TEST_DB}" eventsystem \
  pytest tests/eventsystem_test.py -k "not with_persistence" -v --tb=short
'''
                }
            }
        }
    }
    post {
        always {
            sh '''set +e
docker-compose -f docker-compose.yml down --remove-orphans
docker buildx use default >/dev/null 2>&1 || true
rm -f .jenkins_buildx.env .jenkins_runtime.env .jenkins_stack_images.env
docker logout docker.io >/dev/null 2>&1 || true
'''
        }
        failure {
            echo 'Stack-Pipeline fehlgeschlagen – Buildx/Compose/Test-Logs prüfen.'
        }
        success {
            echo 'Stack-Pipeline OK – Buildx-Flow + Stack-Integrationstests erfolgreich.'
        }
    }
}
