// DFlowP stack pipeline (vereinfachte Full-Flow-Variante mit docker buildx).
// Fokus: klare Stages, parallele Buildx-Builds mit Cache, compose up + Integrationstests.
pipeline {
    agent any
    options {
        timestamps()
        timeout(time: 90, unit: 'MINUTES')
    }
    environment {
        MONGODB_TEST_DB = 'dflowp_test'
    }
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        stage('Preflight tools') {
            steps {
                sh '''set -euo pipefail
docker version
docker buildx version
docker-compose version
'''
            }
        }
        stage('Prepare version & image env') {
            steps {
                sh '''set -euo pipefail
git remote get-url origin >/dev/null 2>&1 && git fetch origin --tags --force || true
LATEST=$(git tag -l 'v[0-9]*.*.*' 2>/dev/null | sort -V | tail -1 || true)
if [ -n "${LATEST}" ]; then
  V=${LATEST#v}; MAJ=${V%%.*}; R1=${V#*.}; MIN=${R1%%.*}
  BN=$(git rev-list --count --all ${LATEST}..HEAD 2>/dev/null || echo 0)
  SOFTWARE_VERSION="v${MAJ}.${MIN}.${BN}"
else
  BN=$(git rev-list --all --count 2>/dev/null || echo 0)
  SOFTWARE_VERSION="v0.1.${BN}"
fi
GIT_SHORT=$(git rev-parse --short=12 HEAD)
ECR_ENDPOINT="${ECR_ENDPOINT:-423623826655.dkr.ecr.eu-central-1.amazonaws.com}"
ECR_REGION="${ECR_REGION:-eu-central-1}"
ECR_REPO_PREFIX="${ECR_REPO_PREFIX:-${ECR_NAMESPACE:-dflowp}}"
IMAGE_REPO_BASE="${ECR_ENDPOINT}"
service_image_repo() {
  local service_name="$1"
  if [ -n "${ECR_REPO_PREFIX}" ]; then
    printf '%s/%s-%s\n' "${IMAGE_REPO_BASE}" "${ECR_REPO_PREFIX}" "${service_name}"
  else
    printf '%s/%s\n' "${IMAGE_REPO_BASE}" "${service_name}"
  fi
}
IMAGE_REPO_MONGO="$(service_image_repo mongo)"
IMAGE_REPO_API="$(service_image_repo api)"
IMAGE_REPO_RUNTIME="$(service_image_repo runtime)"
IMAGE_REPO_EVENTSYSTEM="$(service_image_repo eventsystem)"
IMAGE_REPO_EVENT_BROKER="$(service_image_repo event-broker)"
IMAGE_REPO_PLUGIN_FETCHFEEDITEMS="$(service_image_repo plugin-fetchfeeditems)"
IMAGE_REPO_PLUGIN_EMBEDDATA="$(service_image_repo plugin-embeddata)"
IMAGE_REPO_PLUGIN_CLUSTERING_DBSCAN="$(service_image_repo plugin-clustering-dbscan)"
IMAGE_REPO_PLUGIN_CLUSTERING_HDBSCAN="$(service_image_repo plugin-clustering-hdbscan)"
ECR_CACHE_REPO="${ECR_CACHE_REPO:-$(service_image_repo buildcache)}"
ECR_PULLTHROUGH_ENDPOINT="${ECR_PULLTHROUGH_ENDPOINT:-${ECR_ENDPOINT}}"
ECR_PULLTHROUGH_PREFIX="${ECR_PULLTHROUGH_PREFIX:-docker-hub}"
PULL_PARALLEL="${PULL_PARALLEL:-15}"

cat > .jenkins_runtime.env <<EOF
SOFTWARE_VERSION=${SOFTWARE_VERSION}
GIT_SHORT=${GIT_SHORT}
ECR_ENDPOINT=${ECR_ENDPOINT}
ECR_REGION=${ECR_REGION}
ECR_REPO_PREFIX=${ECR_REPO_PREFIX}
IMAGE_REPO_BASE=${IMAGE_REPO_BASE}
ECR_CACHE_REPO=${ECR_CACHE_REPO}
ECR_PULLTHROUGH_ENDPOINT=${ECR_PULLTHROUGH_ENDPOINT}
ECR_PULLTHROUGH_PREFIX=${ECR_PULLTHROUGH_PREFIX}
PULL_PARALLEL=${PULL_PARALLEL}
EOF

cat > .jenkins_stack_images.env <<EOF
DOCKER_IMAGE_MONGO=${IMAGE_REPO_MONGO}:${SOFTWARE_VERSION}
DOCKER_IMAGE_API=${IMAGE_REPO_API}:${SOFTWARE_VERSION}
DOCKER_IMAGE_RUNTIME=${IMAGE_REPO_RUNTIME}:${SOFTWARE_VERSION}
DOCKER_IMAGE_EVENTSYSTEM=${IMAGE_REPO_EVENTSYSTEM}:${SOFTWARE_VERSION}
DOCKER_IMAGE_EVENT_BROKER=${IMAGE_REPO_EVENT_BROKER}:${SOFTWARE_VERSION}
DOCKER_IMAGE_PLUGIN_FETCHFEEDITEMS=${IMAGE_REPO_PLUGIN_FETCHFEEDITEMS}:${SOFTWARE_VERSION}
DOCKER_IMAGE_PLUGIN_EMBEDDATA=${IMAGE_REPO_PLUGIN_EMBEDDATA}:${SOFTWARE_VERSION}
DOCKER_IMAGE_PLUGIN_CLUSTERING_DBSCAN=${IMAGE_REPO_PLUGIN_CLUSTERING_DBSCAN}:${SOFTWARE_VERSION}
DOCKER_IMAGE_PLUGIN_CLUSTERING_HDBSCAN=${IMAGE_REPO_PLUGIN_CLUSTERING_HDBSCAN}:${SOFTWARE_VERSION}
EOF

echo "SOFTWARE_VERSION=${SOFTWARE_VERSION}"
echo "GIT_SHORT=${GIT_SHORT}"
echo "IMAGE_REPO_BASE=${IMAGE_REPO_BASE}"
echo "ECR_CACHE_REPO=${ECR_CACHE_REPO}"
echo "ECR_ENDPOINT=${ECR_ENDPOINT}"
echo "ECR_REGION=${ECR_REGION}"
echo "ECR_REPO_PREFIX=${ECR_REPO_PREFIX}"
echo "ECR_PULLTHROUGH_ENDPOINT=${ECR_PULLTHROUGH_ENDPOINT}"
echo "ECR_PULLTHROUGH_PREFIX=${ECR_PULLTHROUGH_PREFIX}"
echo "PULL_PARALLEL=${PULL_PARALLEL}"
'''
            }
        }
        stage('ECR login') {
            steps {
                sh '''set -euo pipefail
set -a
. ./.jenkins_runtime.env
set +a

: "${ECR_ENDPOINT?}"
: "${ECR_REGION?}"
: "${ECR_PULLTHROUGH_ENDPOINT?}"

login_ecr() {
  local endpoint="$1"
  echo "Login ECR endpoint ${endpoint} (region ${ECR_REGION})"
  aws ecr get-login-password --region "${ECR_REGION}" | docker login --username AWS --password-stdin "${endpoint}"
}

login_ecr "${ECR_ENDPOINT}"
if [ "${ECR_PULLTHROUGH_ENDPOINT}" != "${ECR_ENDPOINT}" ]; then
  login_ecr "${ECR_PULLTHROUGH_ENDPOINT}"
fi
'''
            }
        }
        stage('Prepare Buildx builder') {
            steps {
                sh '''set -euo pipefail
RAW="dflowp-stack-${JOB_BASE_NAME:-job}"
BUILDER_NAME=$(printf '%s' "${RAW}" | tr '[:upper:]' '[:lower:]' | tr -cs 'a-z0-9_.-' '-')
echo "BUILDER_NAME=${BUILDER_NAME}" > .jenkins_buildx.env

if ! docker buildx inspect "${BUILDER_NAME}" >/dev/null 2>&1; then
  docker buildx create --name "${BUILDER_NAME}" --driver docker-container
fi
docker buildx use "${BUILDER_NAME}"
docker buildx inspect --bootstrap
'''
            }
        }
        stage('Build images (buildx parallel + registry cache/push)') {
            steps {
                sh '''set -euo pipefail
set -a
. ./.jenkins_runtime.env
. ./.jenkins_stack_images.env
. ./.jenkins_buildx.env
set +a

: "${BUILDER_NAME?}"
: "${SOFTWARE_VERSION?}"
: "${ECR_CACHE_REPO?}"
: "${IMAGE_REPO_BASE?}"
: "${ECR_PULLTHROUGH_ENDPOINT?}"
: "${ECR_PULLTHROUGH_PREFIX?}"

GIT_REV=$(git rev-parse HEAD)
MAX_PARALLEL=2
PULL_PARALLEL="${PULL_PARALLEL:-15}"
CHECK_PARALLEL="${CHECK_PARALLEL:-${PULL_PARALLEL}}"

pullthrough_library_image_ref() {
  local image_name="$1"
  local image_tag="$2"
  if [ -n "${ECR_PULLTHROUGH_PREFIX}" ]; then
    printf '%s/%s/library/%s:%s\n' "${ECR_PULLTHROUGH_ENDPOINT}" "${ECR_PULLTHROUGH_PREFIX}" "${image_name}" "${image_tag}"
  else
    printf '%s/library/%s:%s\n' "${ECR_PULLTHROUGH_ENDPOINT}" "${image_name}" "${image_tag}"
  fi
}

PYTHON_BASE_IMAGE="$(pullthrough_library_image_ref python 3.11-slim-bookworm)"
MONGO_BASE_IMAGE="$(pullthrough_library_image_ref mongo 7)"
echo "PYTHON_BASE_IMAGE=${PYTHON_BASE_IMAGE}"
echo "MONGO_BASE_IMAGE=${MONGO_BASE_IMAGE}"

declare -A GIT_HASH_CACHE=()

normalize_repo_relative_path() {
  local raw="$1"
  local part
  local -a in_parts out_parts
  raw="${raw#./}"
  IFS='/' read -r -a in_parts <<< "${raw}"
  for part in "${in_parts[@]}"; do
    case "${part}" in
      ""|".")
        continue
        ;;
      "..")
        if [ "${#out_parts[@]}" -gt 0 ] && [ "${out_parts[${#out_parts[@]}-1]}" != ".." ]; then
          unset 'out_parts[${#out_parts[@]}-1]'
        else
          out_parts+=("${part}")
        fi
        ;;
      *)
        out_parts+=("${part}")
        ;;
    esac
  done
  if [ "${#out_parts[@]}" -eq 0 ]; then
    printf '.\n'
  else
    (IFS='/'; printf '%s\n' "${out_parts[*]}")
  fi
}

git_hash_or_none() {
  local path="$1"
  local path_hash
  if [ "${GIT_HASH_CACHE[${path}]+_}" = "_" ]; then
    printf '%s\n' "${GIT_HASH_CACHE[${path}]}"
    return
  fi
  if git cat-file -e "HEAD:${path}" >/dev/null 2>&1; then
    path_hash="$(git rev-parse "HEAD:${path}")"
  else
    path_hash="none"
  fi
  GIT_HASH_CACHE["${path}"]="${path_hash}"
  printf '%s\n' "${path_hash}"
}

editable_dependency_paths() {
  local req_path="$1"
  if [ ! -f "${req_path}" ]; then
    return 0
  fi
  awk '
    {
      line=$0
      sub(/\r$/, "", line)
      sub(/#.*/, "", line)
      if (line ~ /^[[:space:]]*-e[[:space:]]+/) {
        sub(/^[[:space:]]*-e[[:space:]]+/, "", line)
        gsub(/^[[:space:]]+|[[:space:]]+$/, "", line)
        if (line != "") print line
      }
    }
  ' "${req_path}"
}

resolve_dependency_path() {
  local req_path="$1"
  local dep_path="$2"
  local req_dir rel
  dep_path="${dep_path#./}"
  if git cat-file -e "HEAD:${dep_path}" >/dev/null 2>&1; then
    normalize_repo_relative_path "${dep_path}"
    return
  fi
  req_dir="$(dirname "${req_path}")"
  rel="$(normalize_repo_relative_path "${req_dir}/${dep_path}")"
  printf '%s\n' "${rel}"
}

compute_lineage_w_deps() {
  local svc="$1"
  local service_path="$2"
  local dockerfile="$3"
  local req_path="$4"
  local extra_paths_csv="$5"
  local base_kind="$6"
  local dep resolved tokens lineage base_image_ref
  local -a extra_paths

  base_image_ref=""
  case "${base_kind}" in
    python)
      base_image_ref="${PYTHON_BASE_IMAGE}"
      ;;
    mongo)
      base_image_ref="${MONGO_BASE_IMAGE}"
      ;;
  esac

  tokens="$(
    {
      {
        printf '%s\n' "Jenkinsfile.stack"
        printf '%s\n' "$(normalize_repo_relative_path "${service_path}")"
        printf '%s\n' "$(normalize_repo_relative_path "${dockerfile}")"
        if [ -n "${req_path}" ]; then
          printf '%s\n' "$(normalize_repo_relative_path "${req_path}")"
          while IFS= read -r dep; do
            [ -n "${dep}" ] || continue
            resolved="$(resolve_dependency_path "${req_path}" "${dep}")"
            [ -n "${resolved}" ] && printf '%s\n' "${resolved}"
          done < <(editable_dependency_paths "${req_path}")
        fi
        if [ -n "${extra_paths_csv}" ]; then
          IFS=',' read -r -a extra_paths <<< "${extra_paths_csv}"
          for dep in "${extra_paths[@]}"; do
            [ -n "${dep}" ] || continue
            printf '%s\n' "$(normalize_repo_relative_path "${dep}")"
          done
        fi
      } | awk 'NF' | sort -u | while IFS= read -r dep; do
        printf '%s=%s\n' "${dep}" "$(git_hash_or_none "${dep}")"
      done
      if [ -n "${base_image_ref}" ]; then
        printf '__base_image__%s=%s\n' "${base_kind}" "${base_image_ref}"
      fi
    } | sort | paste -sd';' -
  )"
  lineage="$(printf '%s' "${tokens}" | sha256sum | cut -c1-6 | tr 'A-Z' 'a-z')"
  echo "[${svc}] LINEAGE_W_DEPS=${lineage}" >&2
  printf '%s\n' "${lineage}"
}

pull_with_retry() {
  local image_ref="$1"
  local max_attempts=3
  local attempt=1
  while [ "${attempt}" -le "${max_attempts}" ]; do
    if docker pull "${image_ref}"; then
      return 0
    fi
    if [ "${attempt}" -eq "${max_attempts}" ]; then
      return 1
    fi
    echo "Pull fehlgeschlagen (${attempt}/${max_attempts}) fuer ${image_ref}, retry..."
    attempt=$((attempt + 1))
    sleep 3
  done
}

build_target_from_record() {
  IFS='|' read -r svc dockerfile image_repo _ _ _ base_kind _ lineage <<< "$1"
  local cache_ref image_lineage image_software
  local -a build_args
  cache_ref="${ECR_CACHE_REPO}:${svc}"
  image_lineage="${image_repo}:${lineage}"
  image_software="${image_repo}:${SOFTWARE_VERSION}"
  build_args=()
  case "${base_kind}" in
    python)
      build_args+=(--build-arg "PYTHON_BASE_IMAGE=${PYTHON_BASE_IMAGE}")
      ;;
    mongo)
      build_args+=(--build-arg "MONGO_BASE_IMAGE=${MONGO_BASE_IMAGE}")
      ;;
  esac
  echo "[${svc}] Registry-Miss -> buildx push ${image_lineage} + ${image_software}"
  docker buildx build \
    --builder "${BUILDER_NAME}" \
    --file "${dockerfile}" \
    --tag "${image_lineage}" \
    --tag "${image_software}" \
    --push \
    --cache-from "type=registry,ref=${cache_ref}" \
    --cache-to "type=registry,ref=${cache_ref},mode=max" \
    --label "org.opencontainers.image.version=${SOFTWARE_VERSION}" \
    --label "org.opencontainers.image.revision=${GIT_REV}" \
    "${build_args[@]}" \
    .
}

pull_target_from_record() {
  IFS='|' read -r svc _ image_repo _ _ _ _ _ lineage <<< "$1"
  local image_lineage image_software
  image_lineage="${image_repo}:${lineage}"
  image_software="${image_repo}:${SOFTWARE_VERSION}"
  echo "[${svc}] Pull Service-Image aus ECR ${image_lineage}"
  pull_with_retry "${image_lineage}"
  if docker manifest inspect "${image_software}" >/dev/null 2>&1; then
    echo "[${svc}] Software-Tag vorhanden: ${image_software}"
  else
    echo "[${svc}] Software-Tag fehlt, mappe auf ${image_software}"
    docker tag "${image_lineage}" "${image_software}"
    docker push "${image_software}"
  fi
}

check_registry_target_from_record() {
  IFS='|' read -r svc _ image_repo _ _ _ _ _ lineage <<< "$1"
  local image_lineage out_file
  image_lineage="${image_repo}:${lineage}"
  if docker manifest inspect "${image_lineage}" >/dev/null 2>&1; then
    echo "[${svc}] Registry-Hit fuer ${image_lineage}"
    out_file=".jenkins_registry_checks/${svc}.pull"
  else
    echo "[${svc}] Registry-Miss fuer ${image_lineage}"
    out_file=".jenkins_registry_checks/${svc}.build"
  fi
  printf '%s\n' "$1" > "${out_file}"
}

run_jobs_from_file() {
  local max_parallel="$1"
  local worker_fn="$2"
  local list_file="$3"
  local running=0
  local line

  [ -s "${list_file}" ] || return 0
  while IFS= read -r line; do
    [ -n "${line}" ] || continue
    "${worker_fn}" "${line}" &
    running=$((running + 1))
    if [ "${running}" -ge "${max_parallel}" ]; then
      if ! wait -n; then
        wait || true
        return 1
      fi
      running=$((running - 1))
    fi
  done < "${list_file}"
  wait
}

targets=(
  "mongo|Dockerfile.mongo|${DOCKER_IMAGE_MONGO%:*}|dflowp|requirements.txt||mongo|DOCKER_IMAGE_MONGO"
  "api|Dockerfile.api|${DOCKER_IMAGE_API%:*}|dflowp/api|dflowp/api/requirements.txt||python|DOCKER_IMAGE_API"
  "worker|Dockerfile.worker|${DOCKER_IMAGE_RUNTIME%:*}|dflowp/worker|dflowp/worker/requirements.txt||python|DOCKER_IMAGE_RUNTIME"
  "eventsystem|Dockerfile.eventsystem|${DOCKER_IMAGE_EVENTSYSTEM%:*}|dflowp/eventsystem|dflowp/eventsystem/requirements.txt||python|DOCKER_IMAGE_EVENTSYSTEM"
  "event-broker|Dockerfile.event_broker|${DOCKER_IMAGE_EVENT_BROKER%:*}|dflowp/event_broker|dflowp/event_broker/requirements.txt||python|DOCKER_IMAGE_EVENT_BROKER"
  "plugin-fetchfeeditems|Dockerfile.plugin_fetchfeeditems|${DOCKER_IMAGE_PLUGIN_FETCHFEEDITEMS%:*}|dflowp/plugin_fetchfeeditems|dflowp/plugin_fetchfeeditems/requirements.txt||python|DOCKER_IMAGE_PLUGIN_FETCHFEEDITEMS"
  "plugin-embeddata|Dockerfile.plugin_embeddata|${DOCKER_IMAGE_PLUGIN_EMBEDDATA%:*}|dflowp/plugin_embeddata|dflowp/plugin_embeddata/requirements.txt||python|DOCKER_IMAGE_PLUGIN_EMBEDDATA"
  "plugin-clustering-dbscan|Dockerfile.plugin_clustering_dbscan|${DOCKER_IMAGE_PLUGIN_CLUSTERING_DBSCAN%:*}|dflowp/plugin_clustering_dbscan||dflowp-packages/dflowp-core,dflowp-packages/dflowp-processruntime|python|DOCKER_IMAGE_PLUGIN_CLUSTERING_DBSCAN"
  "plugin-clustering-hdbscan|Dockerfile.plugin_clustering_hdbscan|${DOCKER_IMAGE_PLUGIN_CLUSTERING_HDBSCAN%:*}|dflowp/plugin_clustering_hdbscan||dflowp-packages/dflowp-core,dflowp-packages/dflowp-processruntime|python|DOCKER_IMAGE_PLUGIN_CLUSTERING_HDBSCAN"
)

: > .jenkins_all_targets.list
: > .jenkins_build_targets.list
: > .jenkins_pull_targets.list

for target in "${targets[@]}"; do
  IFS='|' read -r svc dockerfile image_repo service_path req_path extra_paths base_kind image_var <<< "${target}"
  lineage="$(compute_lineage_w_deps "${svc}" "${service_path}" "${dockerfile}" "${req_path}" "${extra_paths}" "${base_kind}")"
  image_lineage="${image_repo}:${lineage}"
  target_record="${target}|${lineage}"
  printf '%s\n' "${target_record}" >> .jenkins_all_targets.list
done

rm -rf .jenkins_registry_checks
mkdir -p .jenkins_registry_checks
if [ "${CHECK_PARALLEL}" -le 0 ]; then
  CHECK_PARALLEL=15
fi
echo "Starte Registry Hit/Miss-Checks parallel (CHECK_PARALLEL=${CHECK_PARALLEL})"
run_jobs_from_file "${CHECK_PARALLEL}" check_registry_target_from_record .jenkins_all_targets.list

for target in "${targets[@]}"; do
  IFS='|' read -r svc _ <<< "${target}"
  if [ -f ".jenkins_registry_checks/${svc}.pull" ]; then
    cat ".jenkins_registry_checks/${svc}.pull" >> .jenkins_pull_targets.list
  elif [ -f ".jenkins_registry_checks/${svc}.build" ]; then
    cat ".jenkins_registry_checks/${svc}.build" >> .jenkins_build_targets.list
  else
    echo "[${svc}] Fehler: Kein Hit/Miss-Ergebnis vorhanden." >&2
    exit 1
  fi
done
rm -rf .jenkins_registry_checks

if [ -s .jenkins_build_targets.list ]; then
  echo "Starte Build-Jobs (MAX_PARALLEL=${MAX_PARALLEL})"
  run_jobs_from_file "${MAX_PARALLEL}" build_target_from_record .jenkins_build_targets.list
else
  echo "Keine Build-Jobs notwendig."
fi

cat .jenkins_build_targets.list >> .jenkins_pull_targets.list

if [ "${PULL_PARALLEL}" -le 0 ]; then
  PULL_PARALLEL="${#targets[@]}"
fi
echo "Starte Pull-Jobs aus ECR Service-Repositories (PULL_PARALLEL=${PULL_PARALLEL})"
run_jobs_from_file "${PULL_PARALLEL}" pull_target_from_record .jenkins_pull_targets.list

rm -f .jenkins_stack_images.env
while IFS='|' read -r _ _ image_repo _ _ _ _ image_var lineage; do
  printf '%s=%s:%s\n' "${image_var}" "${image_repo}" "${lineage}" >> .jenkins_stack_images.env
done < .jenkins_all_targets.list

rm -f .jenkins_all_targets.list .jenkins_build_targets.list .jenkins_pull_targets.list
'''
            }
        }
        stage('Compose up') {
            steps {
                withCredentials([
                    usernamePassword(credentialsId: 'mongodb-creds', usernameVariable: 'MONGODB_USERNAME', passwordVariable: 'MONGODB_PASSWORD'),
                    string(credentialsId: 'openai-api-key', variable: 'OPENAI_API_KEY'),
                    string(credentialsId: 'DFlowP_API_Key', variable: 'DFlowP_API_Key')
                ]) {
                    sh '''set -euo pipefail
set -a
. ./.jenkins_runtime.env
. ./.jenkins_stack_images.env
set +a

unwrap_one() {
  _n="$1"; _v="$2"
  case "${_v}" in
    "{")
      printf %s "${_v}"
      ;;
    "{"*)
      echo "${_v}" | jq -r --arg k "${_n}" 'if type == "object" then .[$k] // . else . end' 2>/dev/null | sed -n '1p'
      ;;
    *)
      printf %s "${_v}"
      ;;
  esac
}

export OPENAI_API_KEY=$(unwrap_one "OPENAI_API_KEY" "${OPENAI_API_KEY:-}")
export DFlowP_API_Key=$(unwrap_one "DFlowP_API_Key" "${DFlowP_API_Key:-}")
export SOFTWARE_VERSION

pullthrough_library_image_ref() {
  local image_name="$1"
  local image_tag="$2"
  if [ -n "${ECR_PULLTHROUGH_PREFIX:-}" ]; then
    printf '%s/%s/library/%s:%s\n' "${ECR_PULLTHROUGH_ENDPOINT}" "${ECR_PULLTHROUGH_PREFIX}" "${image_name}" "${image_tag}"
  else
    printf '%s/library/%s:%s\n' "${ECR_PULLTHROUGH_ENDPOINT}" "${image_name}" "${image_tag}"
  fi
}

ALPINE_CHMOD_IMAGE="$(pullthrough_library_image_ref alpine 3.20)"

mkdir -p volumes/mongo
if ! chmod a+rwx volumes/mongo 2>/dev/null && ! chmod 777 volumes/mongo 2>/dev/null; then
  docker run --rm --user root -v "$(pwd)/volumes/mongo:/v:rw" "${ALPINE_CHMOD_IMAGE}" sh -ceu 'chmod -R 777 /v' || true
fi

docker-compose -f docker-compose.yml down --remove-orphans 2>/dev/null || true
docker-compose -f docker-compose.yml config -q
compose_image_vars=(
  DOCKER_IMAGE_MONGO
  DOCKER_IMAGE_API
  DOCKER_IMAGE_RUNTIME
  DOCKER_IMAGE_EVENTSYSTEM
  DOCKER_IMAGE_EVENT_BROKER
  DOCKER_IMAGE_PLUGIN_FETCHFEEDITEMS
  DOCKER_IMAGE_PLUGIN_EMBEDDATA
  DOCKER_IMAGE_PLUGIN_CLUSTERING_DBSCAN
  DOCKER_IMAGE_PLUGIN_CLUSTERING_HDBSCAN
)

missing_images=()
for image_var in "${compose_image_vars[@]}"; do
  image_ref="${!image_var:-}"
  if [ -z "${image_ref}" ]; then
    echo "Pflichtvariable fehlt: ${image_var}" >&2
    exit 1
  fi
  if docker image inspect "${image_ref}" >/dev/null 2>&1; then
    echo "[compose] lokal vorhanden: ${image_ref}"
  else
    missing_images+=("${image_ref}")
  fi
done

if [ "${#missing_images[@]}" -gt 0 ]; then
  compose_pull_parallel="${PULL_PARALLEL:-15}"
  if [ "${compose_pull_parallel}" -le 0 ]; then
    compose_pull_parallel="${#missing_images[@]}"
  fi
  echo "[compose] ${#missing_images[@]} fehlende Images -> paralleler Pull (PULL_PARALLEL=${compose_pull_parallel})"
  running=0
  for image_ref in "${missing_images[@]}"; do
    docker pull "${image_ref}" &
    running=$((running + 1))
    if [ "${running}" -ge "${compose_pull_parallel}" ]; then
      if ! wait -n; then
        wait || true
        exit 1
      fi
      running=$((running - 1))
    fi
  done
  wait
else
  echo "[compose] Alle Images bereits lokal; kein serieller compose pull notwendig."
fi

docker-compose -f docker-compose.yml up -d --no-build mongo api worker eventsystem event-broker plugin-fetchfeeditems plugin-embeddata plugin-clustering-dbscan plugin-clustering-hdbscan
docker-compose -f docker-compose.yml ps
'''
                }
            }
        }
        stage('Integration tests (API, Runtime, Plugins, Events)') {
            steps {
                withCredentials([
                    usernamePassword(credentialsId: 'mongodb-creds', usernameVariable: 'MONGODB_USERNAME', passwordVariable: 'MONGODB_PASSWORD'),
                    string(credentialsId: 'openai-api-key', variable: 'OPENAI_API_KEY'),
                    string(credentialsId: 'DFlowP_API_Key', variable: 'DFlowP_API_Key')
                ]) {
                    sh '''set -euo pipefail
set -a
. ./.jenkins_runtime.env
. ./.jenkins_stack_images.env
set +a

unwrap_one() {
  _n="$1"; _v="$2"
  case "${_v}" in
    "{")
      printf %s "${_v}"
      ;;
    "{"*)
      echo "${_v}" | jq -r --arg k "${_n}" 'if type == "object" then .[$k] // . else . end' 2>/dev/null | sed -n '1p'
      ;;
    *)
      printf %s "${_v}"
      ;;
  esac
}

export OPENAI_API_KEY=$(unwrap_one "OPENAI_API_KEY" "${OPENAI_API_KEY:-}")
export DFlowP_API_Key=$(unwrap_one "DFlowP_API_Key" "${DFlowP_API_Key:-}")
export SOFTWARE_VERSION

docker-compose -f docker-compose.yml run --rm -e "MONGODB_TEST_DB=${MONGODB_TEST_DB}" api \
  pytest tests/api_test.py -v --tb=short

docker-compose -f docker-compose.yml run --rm -e "MONGODB_TEST_DB=${MONGODB_TEST_DB}" worker \
  pytest tests/process_test.py tests/runtime_event_listener_test.py tests/logging_test.py tests/database_test.py -v --tb=short

docker-compose -f docker-compose.yml run --rm plugin-fetchfeeditems \
  pytest tests/plugin_services_test.py::test_plugin_directories_exist tests/plugin_services_test.py::test_fetch_plugin_info_and_health -v --tb=short

docker-compose -f docker-compose.yml run --rm plugin-embeddata \
  pytest tests/plugin_services_test.py::test_embed_plugin_info_and_health -v --tb=short

docker-compose -f docker-compose.yml run --rm -e "MONGODB_TEST_DB=${MONGODB_TEST_DB}" event-broker \
  pytest tests/event_broker_test.py -v --tb=short

docker-compose -f docker-compose.yml run --rm -e "MONGODB_TEST_DB=${MONGODB_TEST_DB}" eventsystem \
  pytest tests/eventsystem_test.py -k "not with_persistence" -v --tb=short
'''
                }
            }
        }
    }
    post {
        always {
            sh '''set +e
docker-compose -f docker-compose.yml down --remove-orphans
docker buildx use default >/dev/null 2>&1 || true
rm -f .jenkins_buildx.env .jenkins_runtime.env .jenkins_stack_images.env
docker logout "${ECR_ENDPOINT:-423623826655.dkr.ecr.eu-central-1.amazonaws.com}" >/dev/null 2>&1 || true
if [ "${ECR_PULLTHROUGH_ENDPOINT:-${ECR_ENDPOINT:-423623826655.dkr.ecr.eu-central-1.amazonaws.com}}" != "${ECR_ENDPOINT:-423623826655.dkr.ecr.eu-central-1.amazonaws.com}" ]; then
  docker logout "${ECR_PULLTHROUGH_ENDPOINT}" >/dev/null 2>&1 || true
fi
'''
        }
        failure {
            echo 'Stack-Pipeline fehlgeschlagen – Buildx/Compose/Test-Logs prüfen.'
        }
        success {
            echo 'Stack-Pipeline OK – Buildx-Flow + Stack-Integrationstests erfolgreich.'
        }
    }
}
