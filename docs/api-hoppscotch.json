              "raw": "{\n  \"doc_type\": \"dataset\",\n  \"id\": \"ds_news_input_001\",\n  \"rows\": [\n    {\n      \"title\": \"A\",\n      \"url\": \"https://example.org/a\"\n    },\n    {\n      \"title\": \"B\",\n      \"url\": \"https://example.org/b\"\n    }\n  ]\n}"
