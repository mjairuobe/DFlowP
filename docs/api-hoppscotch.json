              "raw": "{\n  \"doc_type\": \"data\",\n  \"id\": \"data_manual_001\",\n  \"content\": {\n    \"title\": \"Artikel A\",\n    \"url\": \"https://example.org/a\"\n  },\n  \"type\": \"input\"\n}"
