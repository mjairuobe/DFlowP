# UI Bakery On-Premise – Kopie nach docker/uibakery.env und Werte setzen.
# Siehe: https://docs.uibakery.io/on-premise/install-and-update/installing-on-premise-version/manual-w-docker-compose
#
# Lizenz: https://cloud.uibakery.io/settings/on-premise-license

UI_BAKERY_VERSION=latest

# Öffentliche URL, unter der du den Browser öffnest (Loopback + Gateway-Port)
UI_BAKERY_APP_SERVER_NAME=http://127.0.0.1:8010
# Host-Port (Compose mappt ihn auf Gateway-Port 3030 im Container)
UI_BAKERY_PORT=8010

# Pflicht: On-Premise-Lizenzschlüssel von UI Bakery
UI_BAKERY_LICENSE_KEY=

# Secrets – für Produktion mit starken Zufallswerten füllen (setup.sh generiert ähnliche Werte)
UI_BAKERY_JWT_SECRET=CHANGE_ME_JWT
UI_BAKERY_JWT_SERVICE_ACCOUNT_SECRET=CHANGE_ME_JWT_SERVICE_ACCOUNT_55_CHARS_MIN________________________________
UI_BAKERY_JWT_REFRESH_SECRET=CHANGE_ME_REFRESH
UI_BAKERY_CREDENTIALS_SECRET=CHANGE_ME_CRED_32_____________
UI_BAKERY_PROJECT_PRIVATE_KEY_SECRET=CHANGE_ME_PK32______________
UI_BAKERY_AUTH_DEVICE_INFO_SECRET=CHANGE_ME_AUTH_DEV_____________
UI_BAKERY_MFA_SECRET=CHANGE_ME_MFA_________________

UI_BAKERY_INTERNAL_API_URL=http://bakery-back:8080
