# UI Bakery On-Premise – Server: Generieren statt manuell editieren:
#   export UI_BAKERY_ON_PREMISE_LICENSE_KEY_SECRET="…"
#   export UI_BAKERY_APP_SERVER_NAME="https://dflowp.ddns.net/App"  # optional, Default
#   ./docker/generate_uibakery_env.sh
#
# Dann: docker-compose up -d (UI Bakery startet mit dem restlichen Stack)
#
# Siehe: https://docs.uibakery.io/on-premise/install-and-update/installing-on-premise-version/manual-w-docker-compose
# Lizenz: https://cloud.uibakery.io/settings/on-premise-license
#
# Öffentliche URL: muss exakt der Adresse im Browser entsprechen (hier: Reverse-Proxy
# dflowp.ddns.net, Path /App, TLS; Port 443 entfällt in der URL).
# Gateway hört lokal auf 127.0.0.1:8010 (siehe UI_BAKERY_PORT) – Proxy leitet dorthin.

UI_BAKERY_VERSION=latest

UI_BAKERY_APP_SERVER_NAME=https://dflowp.ddns.net/App
UI_BAKERY_PORT=8010

UI_BAKERY_ON_PREMISE_LICENSE_KEY_SECRET=

UI_BAKERY_JWT_SECRET=
UI_BAKERY_JWT_SERVICE_ACCOUNT_SECRET=
UI_BAKERY_JWT_REFRESH_SECRET=
UI_BAKERY_CREDENTIALS_SECRET=
UI_BAKERY_PROJECT_PRIVATE_KEY_SECRET=
UI_BAKERY_AUTH_DEVICE_INFO_SECRET=
UI_BAKERY_MFA_SECRET=

UI_BAKERY_INTERNAL_API_URL=http://bakery-back:8080
