# Remote SSH target for the long-running Vite dev host.
DFLOWP_REMOTE_HMR_SSH_TARGET=ec2-user@dev-host.internal

# Ports on remote host (where Vite and the sync supervisor listen).
DFLOWP_REMOTE_HMR_VITE_PORT=40889
DFLOWP_REMOTE_HMR_SUPERVISOR_PORT=40890

# Local forwarded ports on developer machine / Jenkins agent.
DFLOWP_REMOTE_HMR_LOCAL_VITE_PORT=40889
DFLOWP_REMOTE_HMR_LOCAL_SUPERVISOR_PORT=40890

# Supervisor base URL. Usually through local tunnel.
DFLOWP_REMOTE_HMR_SUPERVISOR_URL=http://127.0.0.1:40890

# Optional shared secret header for supervisor auth (X-Shared-Secret).
DFLOWP_REMOTE_HMR_SHARED_SECRET=

# Default git ref/branch to sync if no CLI arg is passed.
DFLOWP_REMOTE_HMR_REF=add-vite-hmr-remote-server
