{
  "dir": {
    "packages": [
      "dflowp-packages/dflowp-core",
      "dflowp-packages/dflowp-processruntime"
    ],
    "services": [
      "dflowp/api",
      "dflowp/worker",
      "dflowp/eventsystem",
      "dflowp/event_broker",
      "dflowp/plugin_fetchfeeditems",
      "dflowp/plugin_embeddata",
      "dflowp/plugin_clustering_dbscan",
      "dflowp/plugin_clustering_hdbscan",
      "dflowp/plugin_topicprompting"
    ]
  },
  "required_stack_services": ["mongo"],
  "docker": {
    "registry": "docker.io/crawlabase",
    "images": {
      "dflowp/api": "dflowp-api",
      "dflowp/worker": "dflowp-runtime",
      "dflowp/eventsystem": "dflowp-eventsystem",
      "dflowp/event_broker": "dflowp-event-broker",
      "dflowp/plugin_fetchfeeditems": "dflowp-plugin-fetchfeeditems",
      "dflowp/plugin_embeddata": "dflowp-plugin-embeddata",
      "dflowp/plugin_clustering_dbscan": "dflowp-plugin-clustering-dbscan",
      "dflowp/plugin_clustering_hdbscan": "dflowp-plugin-clustering-hdbscan",
      "dflowp/plugin_topicprompting": "dflowp-plugin-topicprompting"
    },
    "containers": {
      "dflowp/api": "dflowp-api",
      "dflowp/worker": "dflowp-worker",
      "dflowp/eventsystem": "dflowp-eventsystem",
      "dflowp/event_broker": "dflowp-event-broker",
      "dflowp/plugin_fetchfeeditems": "dflowp-plugin-fetchfeeditems",
      "dflowp/plugin_embeddata": "dflowp-plugin-embeddata",
      "dflowp/plugin_clustering_dbscan": "dflowp-plugin-clustering-dbscan",
      "dflowp/plugin_clustering_hdbscan": "dflowp-plugin-clustering-hdbscan",
      "dflowp/plugin_topicprompting": "dflowp-plugin-topicprompting"
    },
    "stage_targets": {
      "dflowp/api": "api",
      "dflowp/worker": "runtime",
      "dflowp/eventsystem": "eventsystem",
      "dflowp/event_broker": "event-broker",
      "dflowp/plugin_fetchfeeditems": "plugin-fetchfeeditems",
      "dflowp/plugin_embeddata": "plugin-embeddata",
      "dflowp/plugin_clustering_dbscan": "plugin-clustering-dbscan",
      "dflowp/plugin_clustering_hdbscan": "plugin-clustering-hdbscan",
      "dflowp/plugin_topicprompting": "plugin-topicprompting"
    },
    "build_plan_flags": {
      "dflowp/api": "BUILD_API",
      "dflowp/worker": "BUILD_WORKER",
      "dflowp/eventsystem": "BUILD_EVENTSYSTEM",
      "dflowp/event_broker": "BUILD_EVENT_BROKER",
      "dflowp/plugin_fetchfeeditems": "BUILD_PLUGIN_FETCHFEEDITEMS",
      "dflowp/plugin_embeddata": "BUILD_PLUGIN_EMBEDDATA",
      "dflowp/plugin_clustering_dbscan": "BUILD_PLUGIN_CLUSTERING_DBSCAN",
      "dflowp/plugin_clustering_hdbscan": "BUILD_PLUGIN_CLUSTERING_HDBSCAN",
      "dflowp/plugin_topicprompting": "BUILD_PLUGIN_TOPICPROMPTING"
    }
  },
  "compose": {
    "api": "dflowp/api",
    "worker": "dflowp/worker",
    "eventsystem": "dflowp/eventsystem",
    "event-broker": "dflowp/event_broker",
    "plugin-fetchfeeditems": "dflowp/plugin_fetchfeeditems",
    "plugin-embeddata": "dflowp/plugin_embeddata",
    "plugin-clustering-dbscan": "dflowp/plugin_clustering_dbscan",
    "plugin-clustering-hdbscan": "dflowp/plugin_clustering_hdbscan",
    "plugin-topicprompting": "dflowp/plugin_topicprompting"
  },
  "compose_env": {
    "api": "DOCKER_IMAGE_API",
    "worker": "DOCKER_IMAGE_RUNTIME",
    "eventsystem": "DOCKER_IMAGE_EVENTSYSTEM",
    "event-broker": "DOCKER_IMAGE_EVENT_BROKER",
    "plugin-fetchfeeditems": "DOCKER_IMAGE_PLUGIN_FETCHFEEDITEMS",
    "plugin-embeddata": "DOCKER_IMAGE_PLUGIN_EMBEDDATA",
    "plugin-clustering-dbscan": "DOCKER_IMAGE_PLUGIN_CLUSTERING_DBSCAN",
    "plugin-clustering-hdbscan": "DOCKER_IMAGE_PLUGIN_CLUSTERING_HDBSCAN",
    "plugin-topicprompting": "DOCKER_IMAGE_PLUGIN_TOPICPROMPTING"
  }
}
