// DFlowP Refine-Frontend: Tooling, Workspace-Build (npm) + Docker-Image (Dockerfile-Frontend)
// Quelle: dflowp/frontend/

pipeline {
    agent none

    options {
        timestamps()
    }

    stages {
        stage('Refine-Frontend: npm ci + build') {
            agent {
                docker {
                    image 'node:22-bookworm'
                    args '-u root'
                }
            }
            steps {
                sh '''
                    set -eux
                    node -v
                    npm -v
                    corepack enable
                    corepack prepare pnpm@9 --activate
                    pnpm -v
                    cd dflowp/frontend
                    npm ci
                    npm run build
                '''
            }
        }

        stage('Refine-Frontend: Docker-Image bauen') {
            agent any
            steps {
                sh '''
                    set -eux
                    docker build -f Dockerfile-Frontend -t dflowp-frontend:ci .
                '''
            }
        }

        stage('Refine-Frontend: Image-Smoke (statische dist)') {
            agent any
            steps {
                sh '''
                    set -eux
                    docker run --rm --entrypoint sh dflowp-frontend:ci -c 'test -f /usr/share/nginx/html/index.html'
                '''
            }
        }
    }
}
