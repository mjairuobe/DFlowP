// DFlowP Frontend – nur Container-Umgebung (Node 20+, npm, pnpm) für refine.dev-Builds.
// Kein App-Build, keine Tests, kein Deploy. Frontend-Code: dflowp/frontend/

pipeline {
    agent {
        docker {
            image 'node:22-bookworm'
            // Default-Jenkins-User (uid 1001) darf in offiziellen Node-Images kein `corepack enable`
            // (Symlinks nach /usr/local/bin). Root im Ephemeral-Container ist für CI üblich.
            args '-u root'
        }
    }

    options {
        timestamps()
    }

    stages {
        stage('Refine-Frontend-Umgebung im Container') {
            steps {
                sh '''
                    set -eux
                    node -v
                    npm -v
                    # pnpm: Corepack (in Node 22 enthalten) — Standard für viele Refine-Workflows
                    corepack enable
                    corepack prepare pnpm@9 --activate
                    pnpm -v
                    echo "OK: Node, npm, pnpm stehen im Agent-Image bereit (Workspace: dflowp/frontend bei echten Builds)."
                '''
            }
        }
    }
}
